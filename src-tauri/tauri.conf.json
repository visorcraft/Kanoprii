{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kanoprii",
  "version": "1.7.1",
  "identifier": "com.kanoprii.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kanoprii",
        "width": 950,
        "height": 750,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; font-src 'self'; connect-src 'self' https://github.com/visorcraft/Kanoprii/releases/; object-src 'none'; frame-ancestors 'none';"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/visorcraft/Kanoprii/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1OTk4NjlFNkFFNDg5NjAKUldSZ2llUnFub2FaSmR2bHJGTjNTcDZScTB3d1RpMmhtajIxb0dUOFppZVg3THJHK1hVcHcrdlYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "kanoprii.desktop"
      },
      "rpm": {
        "desktopTemplate": "kanoprii.desktop"
      }
    }
  }
}
